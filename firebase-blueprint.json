{
  "entities": {
    "PageContent": {
      "title": "Page Content",
      "description": "Dynamic content for various pages on the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" },
        "primaryButtonText": { "type": "string" },
        "primaryButtonLink": { "type": "string" },
        "secondaryButtonText": { "type": "string" },
        "secondaryButtonLink": { "type": "string" },
        "sections": { 
          "type": "object",
          "description": "Flexible sections for page-specific content"
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "PortfolioProject": {
      "title": "Portfolio Project",
      "description": "Showcase of completed work",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" },
        "featured": { "type": "boolean" }
      },
      "required": ["title", "category", "imageUrl"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Details of team members showcased in about us",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "List of services offered by the agency",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "iconName": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "description"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for dynamic branding like logo and favicon",
      "type": "object",
      "properties": {
        "agencyName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "accentColor": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/config": {
      "schema": "SiteSettings",
      "description": "Global configuration settings"
    },
    "/pages/{pageId}": {
      "schema": "PageContent",
      "description": "Single document for each page like 'home', 'about', etc."
    },
    "/blogPosts/{postId}": {
      "schema": "PortfolioProject",
      "description": "Collection of portfolio projects (Transitioned from blogPosts)"
    },
    "portfolio": {
      "schema": "PortfolioProject",
      "description": "Legacy reference for new portfolio projects"
    },
    "/teamMembers/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of team members"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of agency services"
    }
  }
}
