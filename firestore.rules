rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == "ahmadhaneef5476@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Connection Test
    match /test/{docId} {
      allow read: if true;
    }

    // Global Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 1. Pages Collection
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Portfolio Projects Collection
    match /blogPosts/{postId} {
      allow get: if true;
      allow list: if true;
      
      function isValidProject(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.category is string && data.category.size() <= 100 &&
               data.imageUrl is string && data.imageUrl.size() <= 1000;
      }

      allow create: if isAdmin() && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    // 3. Team Members Collection
    match /teamMembers/{memberId} {
      allow read: if true;
      
      function isValidTeamMember(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.role is string && data.role.size() <= 100 &&
               data.bio is string && data.bio.size() <= 2000 &&
               data.imageUrl is string && data.imageUrl.size() <= 1000 &&
               data.order is number;
      }

      allow create: if isAdmin() && isValidTeamMember(incoming());
      allow update: if isAdmin() && isValidTeamMember(incoming());
      allow delete: if isAdmin();
    }

    // 4. Services Collection
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(serviceId);
    }
  }
}
